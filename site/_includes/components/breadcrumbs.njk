<nav class="breadcrumbs" aria-label="Breadcrumb">
  <a href="/">Home</a>
  {% for crumb in breadcrumbs %}
    <span aria-hidden="true">/</span>
    {% if crumb.url %}
      <a href="{{ crumb.url }}">{{ crumb.label }}</a>
    {% else %}
      <span>{{ crumb.label }}</span>
    {% endif %}
  {% endfor %}
</nav>

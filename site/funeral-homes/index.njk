---
layout: layouts/base.njk
pageTitle: "Funeral Homes in Schuylkill County, PA"
description: "Complete directory of funeral homes in Schuylkill County, Pennsylvania. All locally owned and operated. Phone numbers, ratings, and directions."
---

<div class="container">
  {% set breadcrumbs = [{label: "Funeral Homes"}] %}
  {% include "components/breadcrumbs.njk" %}

  <h1>Funeral Homes in Schuylkill County</h1>
  <p class="page-intro">
    Every funeral home in Schuylkill County is locally owned and operated. Browse by city to find a provider near you.
  </p>

  {% set items = businesses.byCategory["funeral-homes"].items %}
  {% for group in items | by_city %}
    <div class="city-section">
      <h2>{{ group.city }}</h2>
      <div class="card-grid">
        {% for item in group.items %}
          {% include "components/listing-card.njk" %}
        {% endfor %}
      </div>
    </div>
  {% endfor %}
</div>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Funeral Homes in Schuylkill County, PA",
  "numberOfItems": {{ items.length }},
  "itemListElement": [
    {% for item in items %}
    {
      "@type": "ListItem",
      "position": {{ loop.index }},
      "url": "{{ site.url }}{{ item.url }}"
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
</script>
